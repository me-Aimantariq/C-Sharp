
@{
    ViewBag.Title = "index";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Calculator Form</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5">
        <div class="card p-4 shadow">
            <h3 class="mb-4">Simple Calculator</h3>
            @using (Html.BeginForm())
            {
                <div class="mb-3">

                    <label class="form-label">First Number</label>
                    <input type="number" id="num1" name="num1" class="form-control" placeholder="Enter first number">
                </div>

                <div class="mb-3">
                    <label class="form-label">Second Number</label>
                    <input type="number" id="num2" name="num2" class="form-control" placeholder="Enter second number">
                </div>

                <div class="mb-3">
                    <label class="form-label">Operator</label>
                    <select name="operation" id="operator" class="form-select">
                        <option value="Add">Addition</option>
                        <option value="Subtract">Subtraction</option>
                        <option value="Multiply">Multiply</option>
                        <option value="Divide">Division</option>
                    </select>
                </div>

                <button class="btn btn-primary w-100">Calculate</button>
            }

            @if (ViewBag.data != null)
            {
                <div class="alert alert-info mt-3 text-center" role="alert">
                    @ViewBag.data
                </div>
            }

</body>
</html>